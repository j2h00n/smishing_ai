modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ API_PORT=3001 AI_PORT=3002 python3 smishing_ai_server.py & PORT=5000 BASE_PATH=/ API_PORT=3001 AI_PORT=3002 node artifacts/api-server/src/index.js & PORT=5000 BASE_PATH=/ API_PORT=3001 pnpm --filter @workspace/smishing-detector run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=5000 BASE_PATH=/ API_PORT=3001 node artifacts/api-server/src/index.js & npx serve -s smishing-detector/dist/public -l 5000"]
build = ["bash", "-c", "pnpm --filter @workspace/smishing-detector run build"]
